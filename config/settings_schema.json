[
  {
    "name": "theme_info",
    "theme_name": "E4N — Everything 4 Nothing",
    "theme_version": "1.0.0",
    "theme_author": "E4N",
    "theme_documentation_url": "https://shopify.dev/themes",
    "theme_support_url": "https://shopify.dev/themes"
  },
  {
    "name": "Brand",
    "settings": [
      { "type": "image_picker", "id": "logo", "label": "Logo image", "info": "The E4N monogram. Used as a global default for header and footer." },
      { "type": "image_picker", "id": "favicon", "label": "Favicon" },
      { "type": "paragraph", "content": "Fonts: Cardo (editorial serif) and Inter (UI) load automatically. The display font 'Owned' is used for the full name 'Everything 4 Nothing' — add owned.woff2 to /assets to enable it (it falls back to Cardo)." }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "header", "content": "Surfaces" },
      { "type": "color", "id": "color_bg", "label": "Background (charcoal)", "default": "#111111" },
      { "type": "color", "id": "color_surface", "label": "Surface (dark gray)", "default": "#1b1b1b" },
      { "type": "color", "id": "color_surface_2", "label": "Raised surface (graphite)", "default": "#2a2a2a" },
      { "type": "header", "content": "Text" },
      { "type": "color", "id": "color_text", "label": "Text (off white)", "default": "#f2f2f2" },
      { "type": "color", "id": "color_text_dim", "label": "Muted text (silver)", "default": "#b8b8b8" }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      { "type": "range", "id": "page_width", "min": 1200, "max": 1700, "step": 20, "unit": "px", "label": "Max content width", "default": 1480 },
      { "type": "checkbox", "id": "show_grain", "label": "Film grain overlay", "default": true }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      { "type": "checkbox", "id": "card_hover_swap", "label": "Swap to second image on hover", "default": true },
      { "type": "checkbox", "id": "card_quick_shop", "label": "Show Quick Shop on hover", "default": true }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      { "type": "select", "id": "cart_type", "label": "Cart type", "default": "drawer", "options": [ { "value": "drawer", "label": "Slide-out drawer" }, { "value": "page", "label": "Cart page" } ] }
    ]
  },
  {
    "name": "Social",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_tiktok", "label": "TikTok URL" },
      { "type": "text", "id": "social_twitter", "label": "X / Twitter URL" },
      { "type": "text", "id": "social_youtube", "label": "YouTube URL" }
    ]
  }
