<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#111111">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64 }}">
    {%- endif -%}

    <title>
      {{ page_title }}{% if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- comment -%} Fonts: Cardo (editorial serif) + Inter (UI). "Owned" is local via base.css {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cardo:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    {{ content_for_header }}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      window.E4N = { moneyFormat: {{ shop.money_format | json }}, routes: { cart_add: "{{ routes.cart_add_url }}", cart_change: "{{ routes.cart_change_url }}", cart: "{{ routes.cart_url }}" } };
    </script>
    {{ 'global.js' | asset_url | script_tag }}
  </head>

  <body class="template-{{ request.page_type | handle }}">
    <a class="visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_content' | t | default: 'Skip to content' }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- comment -%} Cart drawer + overlay are global {%- endcomment -%}
    {% render 'cart-drawer' %}
    <div class="overlay" data-overlay></div>

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t | default: 'Choosing a selection results in a full page refresh.' }}</li>
    </ul>
  </body>
</html>
