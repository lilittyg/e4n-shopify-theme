<section class="hero" data-section-type="password" style="min-height:100svh">
  <div class="hero__media" data-parallax="0.12">
    <img src="{{ 'hero-rooftop.png' | asset_url }}" alt="E4N" width="2400" height="1600" loading="eager">
  </div>
  <div class="hero__inner text-center" style="margin-inline:auto; max-width:760px">
    <a class="header__logo" href="#" style="justify-content:center; display:flex; margin-bottom:28px">
      <img src="{{ 'e4n-logo.jpg' | asset_url }}" alt="{{ shop.name }}" style="height:64px; width:auto">
    </a>
    <p class="eyebrow" data-reveal>Coming after midnight</p>
    <h1 class="font-brand" style="font-size:clamp(2rem,7vw,4.5rem); margin-top:14px" data-reveal data-reveal-delay="1">Everything 4 Nothing</h1>
    <p class="lead mt-s" data-reveal data-reveal-delay="2">{{ section.settings.subtext | default: 'A dark luxury streetwear label made in numbered runs. The drop is loading.' }}</p>

    <div data-reveal data-reveal-delay="3" style="margin-top:36px">
      {%- form 'storefront_password', class: 'signup-form', style: 'max-width:520px; margin-inline:auto' -%}
        <input type="password" name="password" placeholder="Enter password" aria-label="Store password" required>
        <button type="submit" class="btn">Enter</button>
      {%- endform -%}
      {%- if form.errors -%}<p class="form-note" style="color:#e0a3a3">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>{%- endif -%}
    </div>

    <p class="form-note" style="margin-top:28px">
      {{ 'general.newsletter.subscribe' | t | default: 'Join' }} the list —
      {%- form 'customer', style: 'display:inline-flex; gap:8px; margin-left:8px' -%}
        <input type="hidden" name="contact[tags]" value="prelaunch">
        <input type="email" name="contact[email]" placeholder="Email" required style="background:transparent; border:1px solid var(--line-strong); color:var(--text); padding:8px 12px; font-size:12px">
        <button type="submit" class="link-underline">Notify me</button>
      {%- endform -%}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "A dark luxury streetwear label made in numbered runs. The drop is loading." }
  ]
}
{% endschema %}
