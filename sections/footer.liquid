{%- liquid
  assign logo = section.settings.logo
-%}

<footer class="footer" role="contentinfo">
  {%- if section.settings.statement != blank -%}
    <div class="footer__statement">
      <p class="font-brand" data-reveal>{{ section.settings.statement }}</p>
    </div>
  {%- endif -%}

  <div class="footer__cols">
    <div class="footer__col footer__brand">
      <a class="footer__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if logo != blank -%}
          <img src="{{ logo | image_url: width: 260 }}" alt="{{ shop.name }}" width="130" height="42" loading="lazy">
        {%- else -%}
          <img src="{{ 'e4n-logo.jpg' | asset_url }}" alt="{{ shop.name }}" width="130" height="42" loading="lazy">
        {%- endif -%}
      </a>
      {%- if section.settings.tagline != blank -%}
        <p class="footer__tag">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'menu' -%}
          <div class="footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            {%- if linklists[block.settings.menu].links.size > 0 -%}
              {%- for link in linklists[block.settings.menu].links -%}
                <a href="{{ link.url }}">{{ link.title }}</a><br>
              {%- endfor -%}
            {%- else -%}
              <a href="{{ routes.all_products_collection_url }}">Shop</a><br>
              <a href="/pages/about">About Us</a><br>
              <a href="/pages/faq">FAQ</a><br>
              <a href="/pages/contact">Contact</a><br>
            {%- endif -%}
          </div>
        {%- when 'newsletter' -%}
          <div class="footer__col" {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading | default: 'Join the Drop' }}</h4>
            <p class="footer__tag" style="margin-top:0">{{ block.settings.text }}</p>
            {%- form 'customer', class: 'signup-form', style: 'margin-top:18px' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <input type="email" name="contact[email]" placeholder="Email address" required aria-label="Email">
              <button type="submit" class="btn">{{ 'general.newsletter.subscribe' | t | default: 'Join' }}</button>
            {%- endform -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  <div class="footer__bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright | default: 'All rights reserved. Made in numbered runs.' }}</span>
    <div class="social">
      {%- if section.settings.instagram != blank -%}<a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', icon: 'instagram' %}</a>{%- endif -%}
      {%- if section.settings.tiktok != blank -%}<a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">{% render 'icon', icon: 'tiktok' %}</a>{%- endif -%}
      {%- if section.settings.twitter != blank -%}<a href="{{ section.settings.twitter }}" target="_blank" rel="noopener" aria-label="X">{% render 'icon', icon: 'x' %}</a>{%- endif -%}
      {%- if section.settings.youtube != blank -%}<a href="{{ section.settings.youtube }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', icon: 'youtube' %}</a>{%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer logo" },
    { "type": "textarea", "id": "statement", "label": "Brand statement", "default": "A dark luxury streetwear label made in numbered runs. Forged for the hours after midnight." },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Everything 4 Nothing. Forged for the hours after midnight." },
    { "type": "header", "content": "Social links" },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "url", "id": "twitter", "label": "X / Twitter URL" },
    { "type": "url", "id": "youtube", "label": "YouTube URL" },
    { "type": "header", "content": "Legal" },
    { "type": "text", "id": "copyright", "label": "Copyright line", "default": "All rights reserved. Made in numbered runs." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Explore" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter column",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Drop" },
        { "type": "text", "id": "text", "label": "Text", "default": "Be first to access future releases and limited collections." }
      ]
    }
  ],
  "enabled_on": { "groups": ["footer"] }
}
{% endschema %}
