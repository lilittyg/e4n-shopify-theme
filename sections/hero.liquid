{%- liquid
  assign img = section.settings.image
-%}
<section class="hero" data-section-type="hero">
  <div class="hero__media" data-parallax="0.18">
    {%- if img != blank -%}
      <img src="{{ img | image_url: width: 2400 }}" alt="{{ section.settings.image_alt | escape }}" width="2400" height="1600" loading="eager" fetchpriority="high">
    {%- else -%}
      <img src="{{ 'hero-rooftop.png' | asset_url }}" alt="E4N — rooftop over the city after midnight" width="2400" height="1600" loading="eager" fetchpriority="high">
    {%- endif -%}
  </div>

  <div class="hero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="hero__mark display" data-reveal data-reveal-delay="1">{{ section.settings.mark | default: 'E4N' }}</h1>
    <span class="hero__brand font-brand" data-reveal data-reveal-delay="2">{{ section.settings.brand_name | default: 'Everything 4 Nothing' }}</span>
    {%- if section.settings.subtext != blank -%}
      <p class="hero__sub lead" data-reveal data-reveal-delay="3">{{ section.settings.subtext }}</p>
    {%- endif -%}
    <div class="hero__cta" data-reveal data-reveal-delay="4">
      {%- if section.settings.button_label != blank -%}
        <a class="btn" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a class="btn btn--ghost" href="{{ section.settings.button_link_2 }}">{{ section.settings.button_label_2 }}</a>
      {%- endif -%}
    </div>
  </div>

  <span class="hero__scroll" aria-hidden="true">{{ section.settings.scroll_label | default: 'Scroll' }}</span>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image", "info": "Cinematic night / rooftop / city. Defaults to the bundled E4N rooftop campaign image." },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "E4N campaign" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "City Night — Limited Drop 001" },
    { "type": "text", "id": "mark", "label": "Large mark", "default": "E4N" },
    { "type": "text", "id": "brand_name", "label": "Brand name (Owned font)", "default": "Everything 4 Nothing" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "A dark luxury streetwear label made in numbered runs. Forged for the hours after midnight." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Collection" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "button_label_2", "label": "Second button label", "default": "The Lookbook" },
    { "type": "url", "id": "button_link_2", "label": "Second button link" },
    { "type": "text", "id": "scroll_label", "label": "Scroll cue label", "default": "Scroll" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
