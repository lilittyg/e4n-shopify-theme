<section class="section" data-section-type="lookbook">
  <div class="container">
    <div class="section-head">
      <div class="section-head__titles">
        {%- if section.settings.eyebrow != blank -%}<p class="eyebrow" data-reveal>{{ section.settings.eyebrow }}</p>{%- endif -%}
        <h2 class="h-lg" data-reveal>{{ section.settings.title | default: 'Lookbook — After Midnight' }}</h2>
      </div>
      {%- if section.settings.link_label != blank -%}
        <a class="link-underline" data-reveal href="{{ section.settings.link_url }}">{{ section.settings.link_label }} →</a>
      {%- endif -%}
    </div>

    <div class="lookbook">
      {%- for block in section.blocks -%}
        {%- liquid
          assign size = block.settings.size | default: 'lb-half'
        -%}
        <a class="lookbook__item {{ size }} img-reveal" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 1600 }}" alt="{{ block.settings.caption | escape }}" loading="lazy">
          {%- else -%}
            <img src="{{ block.settings.fallback | default: 'lookbook-1.png' | asset_url }}" alt="{{ block.settings.caption | escape }}" loading="lazy">
          {%- endif -%}
          {%- if block.settings.caption != blank -%}<span class="lookbook__cap">{{ block.settings.caption }}</span>{%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lookbook",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Editorial" },
    { "type": "text", "id": "title", "label": "Title", "default": "Lookbook — After Midnight" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Enter the Lookbook" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Lookbook image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select", "id": "size", "label": "Tile size", "default": "lb-half",
          "options": [
            { "value": "lb-tall", "label": "Tall (1/3)" },
            { "value": "lb-wide", "label": "Wide (2/3)" },
            { "value": "lb-half", "label": "Half (1/2)" },
            { "value": "lb-third", "label": "Third (1/3)" }
          ]
        },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select", "id": "fallback", "label": "Bundled fallback image", "default": "lookbook-1.png",
          "info": "Used only if no image is uploaded.",
          "options": [
            { "value": "lookbook-1.png", "label": "Model 1" },
            { "value": "lookbook-2.png", "label": "Model 2" },
            { "value": "lookbook-3.png", "label": "Model 3 (back)" },
            { "value": "hero-rooftop.png", "label": "Rooftop group" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook",
      "blocks": [
        { "type": "image", "settings": { "size": "lb-wide", "caption": "Rooftop — 03:14 AM", "fallback": "hero-rooftop.png" } },
        { "type": "image", "settings": { "size": "lb-tall", "caption": "Onyx Hoodie", "fallback": "lookbook-1.png" } },
        { "type": "image", "settings": { "size": "lb-third", "caption": "Skyline Series", "fallback": "lookbook-3.png" } },
        { "type": "image", "settings": { "size": "lb-third", "caption": "Empty Streets", "fallback": "lookbook-2.png" } },
        { "type": "image", "settings": { "size": "lb-third", "caption": "Numbered Run", "fallback": "shirt-back.png" } }
      ]
    }
  ]
}
{% endschema %}
